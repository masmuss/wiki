---
import {
  Collapsible,
  CollapsibleTrigger,
  CollapsibleContent,
} from "@/components/ui/collapsible";
import { ChevronRight } from "@lucide/astro";
import WikiNavNode from "./WikiNavNode.astro";
import { cn } from "@/lib/utils";

export interface TreeNode {
  label: string;
  href?: string;
  children: Record<string, TreeNode>;
}

interface Props {
  node: TreeNode;
  class?: string;
  depth: number;
  currentPath: string;
}

const { node, class: className, depth, currentPath } = Astro.props;

const childrenKeys = Object.keys(node.children).sort((a, b) => {
  const nodeA = node.children[a];
  const nodeB = node.children[b];
  const isAFolder = Object.keys(nodeA.children).length > 0;
  const isBFolder = Object.keys(nodeB.children).length > 0;

  if (!isAFolder && isBFolder) return -1;
  if (isAFolder && !isBFolder) return 1;

  return nodeA.label.localeCompare(nodeB.label);
});
const hasChildren = childrenKeys.length > 0;
const isActive = node.href && currentPath === node.href.replace(/\/$/, "");
const isFolder = !node.href && hasChildren;
const isRootCategory = isFolder && depth === 0;

function getIndentClass(depth: number) {
  if (depth === 1) return "ml-3";
  if (depth === 2) return "ml-6";
  if (depth === 3) return "ml-9";
  if (depth === 4) return "ml-12";
  return "";
}

function isChildActive(n: TreeNode): boolean {
  if (n.href && currentPath === n.href.replace(/\/$/, "")) return true;
  for (const child of Object.values(n.children)) {
    if (isChildActive(child)) return true;
  }
  return false;
}

const shouldBeOpen = isChildActive(node);
---

{
  isFolder ? (
    <Collapsible open={shouldBeOpen} class={cn("flex flex-col", className)}>
      <CollapsibleTrigger class="group/trigger flex w-full cursor-pointer items-center justify-between text-left">
        {isRootCategory ? (
          <span class="block pb-1 pt-4 text-xs font-semibold uppercase tracking-widest text-muted-foreground group-first/trigger:pt-0">
            {node.label}
          </span>
        ) : (
          <span
            class:list={[
              "block py-1 text-xs font-medium text-muted-foreground",
              getIndentClass(depth),
            ]}
          >
            {node.label}
          </span>
        )}
        <ChevronRight class="size-4 text-muted-foreground/50 transition-transform duration-200 group-data-[state=open]/collapsible:rotate-90" />
      </CollapsibleTrigger>
      <CollapsibleContent animation="slide" class="flex flex-col space-y-0.5">
        {childrenKeys.map((key) => (
          <WikiNavNode
            node={node.children[key]}
            depth={depth + 1}
            currentPath={currentPath}
          />
        ))}
      </CollapsibleContent>
    </Collapsible>
  ) : (
    <a
      href={node.href}
      class:list={[
        "block rounded py-px text-sm leading-snug transition-colors",
        getIndentClass(depth),
        className,
        isActive
          ? "font-medium text-primary"
          : "text-muted-foreground hover:text-foreground",
      ]}
    >
      {isActive && <span class="mr-1">&mdash;</span>}
      {node.label}
    </a>
  )
}
